    <summaries>
      <summary>
        <versionCode>00</versionCode>
        <actionDate>2025-10-17</actionDate>
        <actionDesc>Introduced in House</actionDesc>
        <updateDate>2026-04-08T20:25:48Z</updateDate>
        <text><![CDATA[<p>This resolution supports the designation of National Wildlife Refuge Week.</p><p>The resolution acknowledges the importance of national wildlife refuges for their recreational opportunities and contribution to local economies.</p><p>Finally, the resolution reaffirms the support of the House of&nbsp;Representatives for wildlife conservation and the National Wildlife Refuge System.</p>]]></text>
      </summary>
    </summaries>
